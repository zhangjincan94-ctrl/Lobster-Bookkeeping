.greeting-section {
  padding: 24rpx 0 16rpx 0;
}

.greeting-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
}

/* 今日数据卡片 */
.today-card {
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  color: #fff;
  border: none;
}

.today-net {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
}

.today-net-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8rpx;
}

.today-net-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 1rpx;
}

.today-grid {
  display: flex;
  flex-direction: row;
  padding-top: 24rpx;
}

.today-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cell-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 6rpx;
}

.cell-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff !important;
}

.cell-sub {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7) !important;
  margin-top: 4rpx;
}

/* 主操作区 */
.quick-actions {
  padding: 24rpx;
}

.actions-row {
  display: flex;
  flex-direction: row;
}

.actions-row-2 .action-big {
  flex: 1;
}

.actions-row-2 .action-big + .action-big {
  margin-left: 20rpx;
}

.action-big {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  border-radius: 16rpx;
  color: #fff;
}

.action-sale {
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
}

.action-purchase {
  background: linear-gradient(135deg, #4A90E2, #5DA5F2);
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 226, 0.3);
}

.action-big-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.action-big-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #fff;
}

/* 经营提醒 */
.reminder-section {
  padding: 24rpx;
}

.reminder-grid {
  display: flex;
  flex-direction: column;
}

.reminder-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.reminder-item:last-child {
  border-bottom: none;
}

.reminder-label {
  font-size: 28rpx;
  color: #333333;
}

.reminder-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.reminder-sub {
  font-size: 22rpx;
  margin-left: 12rpx;
}

.other-cost-entry {
  padding: 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  border: 1rpx dashed rgba(255, 107, 53, 0.5);
  background-color: #fffaf7;
}

.other-cost-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.other-cost-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999999;
}

.other-cost-action {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF6B35;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background-color: rgba(0, 0, 0, 0.45);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.cost-modal {
  background-color: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx 28rpx 44rpx;
}

.modal-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.modal-close {
  font-size: 42rpx;
  color: #999999;
  padding: 0 8rpx;
}

.type-tabs {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.type-tab {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 16rpx;
  background-color: #f7f7f7;
  color: #666666;
  font-size: 28rpx;
}

.type-tab-active {
  background-color: #fff1e8;
  color: #FF6B35;
  font-weight: bold;
}

.form-row {
  margin-bottom: 20rpx;
}

.form-row-column {
  margin-bottom: 16rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.form-input,
.form-picker {
  height: 82rpx;
  line-height: 82rpx;
  padding: 0 20rpx;
  border-radius: 14rpx;
  background-color: #f7f7f7;
  font-size: 28rpx;
  color: #333333;
}

.cost-hint {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.save-cost-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  background-color: #FF6B35;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: bold;
}

.recent-section {
  padding: 24rpx;
}

.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.section-more {
  font-size: 24rpx;
  color: #FF6B35;
}

.transaction-list {
  display: flex;
  flex-direction: column;
}

.transaction-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.transaction-item:last-child {
  border-bottom: none;
}

.transaction-left {
  display: flex;
  flex-direction: column;
  flex: 1;
  margin-right: 24rpx;
}

.transaction-buyer {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.transaction-type {
  font-size: 24rpx;
  color: #999999;
}

.transaction-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.transaction-amount {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.transaction-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.transaction-time {
  font-size: 22rpx;
  margin-left: 12rpx;
}

.text-cost {
  color: #4A90E2 !important;
}
