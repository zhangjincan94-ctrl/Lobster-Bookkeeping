<view class="container">
  <view class="greeting-section">
    <text class="greeting-text">你好，{{merchantName}}</text>
  </view>

  <view class="today-card card">
    <view class="today-net">
      <text class="today-net-label">今日净收入</text>
      <text class="today-net-value">{{today.net_income}}</text>
    </view>
    <view class="today-grid">
      <view class="today-cell">
        <text class="cell-label">营收</text>
        <text class="cell-value text-income">{{today.sales_amount}}</text>
        <text class="cell-sub text-muted">{{today.sales_count}} 笔</text>
      </view>
      <view class="today-cell">
        <text class="cell-label">未收</text>
        <text class="cell-value text-debt">{{today.sales_unpaid}}</text>
        <text class="cell-sub text-muted">待回款</text>
      </view>
      <view class="today-cell">
        <text class="cell-label">进货</text>
        <text class="cell-value text-cost">{{today.purchase_cost}}</text>
        <text class="cell-sub text-muted">{{today.purchase_count}} 笔 · {{today.purchase_weight}}斤</text>
      </view>
      <view class="today-cell">
        <text class="cell-label">其他成本</text>
        <text class="cell-value">{{today.other_cost}}</text>
        <text class="cell-sub text-muted">人工/耗材</text>
      </view>
    </view>
  </view>

  <view class="card quick-actions">
    <view class="actions-row actions-row-2">
      <view class="action-big action-sale" bindtap="goAddTransaction">
        <text class="action-big-icon">📝</text>
        <text class="action-big-label">记一笔销售</text>
      </view>
      <view class="action-big action-purchase" bindtap="goAddPurchase">
        <text class="action-big-icon">📦</text>
        <text class="action-big-label">记一笔进货</text>
      </view>
    </view>
  </view>

  <view class="card other-cost-entry" bindtap="showOtherCostModal">
    <view>
      <text class="other-cost-title">其他成本</text>
      <text class="other-cost-sub">人工费、包装耗材</text>
    </view>
    <text class="other-cost-action">+ 记录</text>
  </view>

  <view class="card reminder-section">
    <view class="section-header">
      <text class="section-title">经营提醒</text>
    </view>
    <view class="reminder-grid">
      <view class="reminder-item" bindtap="goTransactionList">
        <text class="reminder-label">买家欠款</text>
        <text class="reminder-value text-debt">{{reminders.receivable_amount}}</text>
      </view>
      <view class="reminder-item" bindtap="goPurchaseList">
        <text class="reminder-label">应付供应商款</text>
        <text class="reminder-value text-cost">{{reminders.payable_amount}}</text>
      </view>
      <view class="reminder-item" bindtap="goPurchaseList">
        <text class="reminder-label">当前库存</text>
        <text class="reminder-value">{{reminders.stock_weight}}斤</text>
        <text class="reminder-sub text-muted">{{reminders.stock_count}} 个货源</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showOtherCostModal}}" class="modal-mask" bindtap="hideOtherCostModal">
    <view class="cost-modal" catchtap="stopBubble">
      <view class="modal-header">
        <text class="modal-title">记录其他成本</text>
        <text class="modal-close" bindtap="hideOtherCostModal">×</text>
      </view>
      <view class="type-tabs">
        <view
          wx:for="{{otherCostTypes}}"
          wx:key="key"
          class="type-tab {{otherCostForm.costType === item.key ? 'type-tab-active' : ''}}"
          data-type="{{item.key}}"
          bindtap="onOtherCostTypeTap"
        >{{item.label}}</view>
      </view>
      <view class="form-row">
        <text class="form-label">金额</text>
        <input class="form-input" type="digit" placeholder="请输入费用金额" value="{{otherCostForm.amount}}" bindinput="onOtherCostAmountInput" />
      </view>
      <view class="form-row">
        <text class="form-label">日期</text>
        <picker mode="date" value="{{otherCostForm.costDate}}" bindchange="onOtherCostDateChange">
          <view class="form-picker">{{otherCostForm.costDate}}</view>
        </picker>
      </view>
      <view class="form-row form-row-column">
        <text class="form-label">备注</text>
        <input class="form-input" placeholder="例如 临时工、打包盒、袋子" value="{{otherCostForm.remark}}" bindinput="onOtherCostRemarkInput" />
      </view>
      <view class="cost-hint">包装耗材包含打包盒、袋子、皮筋、冰袋等随销售消耗的材料。</view>
      <button class="save-cost-btn" loading="{{savingOtherCost}}" bindtap="saveOtherCost">保存成本</button>
    </view>
  </view>
</view>
