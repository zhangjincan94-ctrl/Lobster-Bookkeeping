.page {
  padding-bottom: 120rpx;
  min-height: 100vh;
}

.swipe-row {
  position: relative;
  margin: 16rpx 24rpx;
}

.swipe-content {
  position: relative;
  z-index: 2;
  margin: 0;
  background: #fff;
  border-radius: 16rpx;
  transition: transform 0.25s ease;
  will-change: transform;
}

.swipe-action {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 120rpx;
  background: #E74C3C;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border-radius: 16rpx;
  z-index: 1;
}

.search-bar {
  background-color: #ffffff;
  padding: 16rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-input-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  padding: 12rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  height: 40rpx;
}

.buyer-list {
  padding: 16rpx 24rpx;
}

.buyer-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.buyer-left {
  display: flex;
  flex-direction: column;
  flex: 1;
  margin-right: 24rpx;
}

.buyer-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.buyer-phone {
  font-size: 24rpx;
}

.buyer-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.buyer-spent {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.buyer-debt {
  font-size: 24rpx;
}

.buyer-arrow {
  font-size: 36rpx;
  color: #cccccc;
  margin-top: 4rpx;
}

.loading-tip {
  text-align: center;
  padding: 24rpx 0;
  font-size: 24rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 108rpx;
  height: 108rpx;
  border-radius: 54rpx;
  background-color: #FF6B35;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 52rpx;
  color: #ffffff;
  line-height: 1;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  padding: 32rpx 24rpx 16rpx;
  color: #333333;
}

.modal-body {
  padding: 16rpx 24rpx;
}

.modal-field {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-field:last-child {
  border-bottom: none;
}

.modal-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
}

.modal-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  text-align: right;
}

.modal-actions {
  display: flex;
  flex-direction: row;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  font-size: 30rpx;
  padding: 24rpx 0;
  text-align: center;
  border: none;
  border-radius: 0;
  line-height: 1.5;
  background-color: #ffffff;
}

.modal-btn::after {
  border: none;
}

.modal-btn-cancel {
  color: #999999;
  border-right: 1rpx solid #f0f0f0;
}

.modal-btn-confirm {
  color: #FF6B35;
  font-weight: bold;
}
