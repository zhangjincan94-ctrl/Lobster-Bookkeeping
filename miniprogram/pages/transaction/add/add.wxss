.page {
  padding-bottom: 140rpx;
  min-height: 100vh;
}

.form-card {
  background-color: #ffffff;
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  text-align: right;
  padding: 8rpx 0;
}

.form-textarea {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  width: 100%;
  min-height: 120rpx;
  padding: 8rpx 0;
}

.form-picker {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  font-size: 28rpx;
  color: #333333;
  padding: 8rpx 0;
}

.picker-arrow {
  margin-left: 8rpx;
  color: #cccccc;
  font-size: 24rpx;
}

.buyer-dropdown {
  position: absolute;
  left: 0;
  right: 0;
  top: 100%;
  background-color: #ffffff;
  border: 1rpx solid #eeeeee;
  border-radius: 8rpx;
  max-height: 320rpx;
  overflow-y: auto;
  z-index: 50;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.buyer-dropdown-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
}

.buyer-dropdown-item:last-child {
  border-bottom: none;
}

.total-amount {
  flex: 1;
  text-align: right;
  font-size: 34rpx;
  font-weight: bold;
}

.radio-group {
  flex: 1;
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
}

.radio-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-left: 24rpx;
  font-size: 28rpx;
}

.source-summary {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.source-summary-text {
  display: flex;
  flex-direction: column;
  font-size: 26rpx;
  line-height: 1.7;
}

.source-select-btn,
.source-option-btn,
.source-modal-close {
  background-color: #FF6B35;
  color: #ffffff;
  border: none;
  border-radius: 10rpx;
  font-size: 26rpx;
  padding: 10rpx 20rpx;
  line-height: 1.5;
}

.source-select-btn::after,
.source-option-btn::after,
.source-modal-close::after {
  border: none;
}

.source-empty {
  font-size: 24rpx;
  padding-top: 18rpx;
}

.source-selected-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 18rpx 0;
  border-top: 1rpx solid #f5f5f5;
}

.source-selected-info,
.source-option-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  margin-right: 16rpx;
}

.source-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.source-meta {
  font-size: 22rpx;
}

.source-weight-input {
  width: 120rpx;
  font-size: 28rpx;
  text-align: right;
  color: #333333;
  padding: 8rpx;
  border: 1rpx solid #eeeeee;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.source-remove {
  font-size: 24rpx;
  color: #E74C3C;
}

.source-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.source-modal-content {
  width: 100%;
  max-height: 72vh;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.source-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 20rpx;
}

.source-modal-empty {
  text-align: center;
  font-size: 26rpx;
  padding: 56rpx 0;
}

.source-option-list {
  max-height: 50vh;
}

.source-option-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.source-modal-close {
  width: 100%;
  margin-top: 20rpx;
  padding: 18rpx 0;
  font-size: 30rpx;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  background-color: #FF6B35;
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 12rpx;
  padding: 20rpx 0;
  text-align: center;
  line-height: 1.5;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  background-color: #ffb088;
  color: #ffffff;
}
