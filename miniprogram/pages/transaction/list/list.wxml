<view class="page">
  <view class="filter-bar">
    <scroll-view class="status-tabs" scroll-x="true">
      <view
        class="status-tab {{activeStatus === '' ? 'status-tab-active' : ''}}"
        bindtap="onStatusTap"
        data-status=""
      >全部</view>
      <view
        class="status-tab {{activeStatus === '0' ? 'status-tab-active' : ''}}"
        bindtap="onStatusTap"
        data-status="0"
      >未付款</view>
      <view
        class="status-tab {{activeStatus === '2' ? 'status-tab-active' : ''}}"
        bindtap="onStatusTap"
        data-status="2"
      >部分付款</view>
      <view
        class="status-tab {{activeStatus === '1' ? 'status-tab-active' : ''}}"
        bindtap="onStatusTap"
        data-status="1"
      >已付款</view>
    </scroll-view>
  </view>

  <view class="date-filter">
    <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
      <view class="date-picker">
        <text class="{{startDate ? '' : 'text-muted'}}">{{startDate || '开始日期'}}</text>
      </view>
    </picker>
    <text class="date-separator">至</text>
    <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
      <view class="date-picker">
        <text class="{{endDate ? '' : 'text-muted'}}">{{endDate || '结束日期'}}</text>
      </view>
    </picker>
  </view>

  <view wx:if="{{transactions.length === 0 && !loading}}" class="empty-state">
    <text class="empty-text">暂无交易记录</text>
  </view>

  <view wx:else class="transaction-list">
    <view
      class="transaction-item card"
      wx:for="{{transactions}}"
      wx:key="id"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <view class="transaction-left">
        <text class="transaction-buyer">{{item.buyerName}}</text>
        <text class="transaction-sub text-muted">{{item.lobsterSize}} {{item.weight ? item.weight + '斤' : ''}}</text>
      </view>
      <view class="transaction-right">
        <text class="transaction-amount text-price">{{item.totalAmountDisplay}}</text>
        <view class="transaction-bottom-row">
          <text class="transaction-time text-muted">{{item.timeDisplay}}</text>
          <text class="tag {{item.paymentStatusClass}}">{{item.paymentStatusText}}</text>
        </view>
      </view>
    </view>
    <view wx:if="{{loading}}" class="loading-tip">
      <text class="text-muted">加载中...</text>
    </view>
    <view wx:if="{{!hasMore && transactions.length > 0}}" class="loading-tip">
      <text class="text-muted">没有更多了</text>
    </view>
  </view>

  <view class="fab" bindtap="goAddTransaction">
    <text class="fab-icon">+</text>
  </view>
</view>
