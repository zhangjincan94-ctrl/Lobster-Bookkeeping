.page {
  padding-bottom: 140rpx;
  min-height: 100vh;
}

.detail-card {
  margin: 16rpx 24rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #999999;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  text-align: right;
  margin-left: 24rpx;
  word-break: break-all;
}

.payment-action,
.delivery-action {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.remark-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.payment-record {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.payment-record:last-child {
  border-bottom: none;
}

.payment-record-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.payment-record-amount {
  font-size: 28rpx;
  color: #27AE60;
  font-weight: 500;
  margin-right: 16rpx;
}

.payment-record-method {
  font-size: 24rpx;
}

.payment-record-time {
  font-size: 24rpx;
}

.source-record {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.source-record:last-child {
  border-bottom: none;
}

.source-record-left {
  display: flex;
  flex-direction: column;
  flex: 1;
  margin-right: 20rpx;
}

.source-record-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.source-record-meta {
  font-size: 24rpx;
  margin-top: 4rpx;
}

.source-record-cost {
  font-size: 28rpx;
  flex-shrink: 0;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.bottom-btn {
  flex: 1;
}

.btn-danger {
  background-color: #ffffff;
  color: #E74C3C;
  border: 2rpx solid #E74C3C;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  text-align: center;
  line-height: 1.5;
}

.btn-danger::after {
  border: none;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  padding: 32rpx 24rpx 16rpx;
  color: #333333;
}

.modal-body {
  padding: 16rpx 24rpx;
}

.modal-field {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-field:last-child {
  border-bottom: none;
}

.modal-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
}

.modal-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  text-align: right;
  min-height: 56rpx;
  line-height: 56rpx;
}

.modal-picker {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  text-align: right;
  padding: 8rpx 0;
}

.modal-actions {
  display: flex;
  flex-direction: row;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  font-size: 30rpx;
  padding: 24rpx 0;
  text-align: center;
  border: none;
  border-radius: 0;
  line-height: 1.5;
  background-color: #ffffff;
}

.modal-btn::after {
  border: none;
}

.modal-btn-cancel {
  color: #999999;
  border-right: 1rpx solid #f0f0f0;
}

.modal-btn-confirm {
  color: #FF6B35;
  font-weight: bold;
}
