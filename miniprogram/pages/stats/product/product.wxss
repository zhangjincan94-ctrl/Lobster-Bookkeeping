.page {
  padding-bottom: 40rpx;
  min-height: 100vh;
}

.filter-card {
  margin: 16rpx 24rpx;
  padding: 16rpx 24rpx;
}

.filter-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.picker-item {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.picker-label {
  font-size: 22rpx;
  color: #999999;
}

.picker-value {
  font-size: 28rpx;
  color: #333333;
  margin-top: 4rpx;
}

.picker-sep {
  font-size: 26rpx;
  color: #999999;
  padding: 0 16rpx;
}

.summary-card {
  margin: 0 24rpx 16rpx;
  padding: 24rpx 12rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-around;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.summary-value {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 22rpx;
  color: #999999;
}

.winner-card,
.chart-card {
  margin: 0 24rpx 16rpx;
  padding: 24rpx;
}

.winner-card {
  background: linear-gradient(135deg, #FF6B35 0%, #FF9F43 100%);
  color: #ffffff;
}

.winner-label {
  font-size: 24rpx;
  opacity: 0.88;
}

.winner-main {
  margin-top: 14rpx;
}

.winner-name {
  display: block;
  font-size: 42rpx;
  font-weight: bold;
}

.winner-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.92;
}

.winner-reason {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.25);
  font-size: 23rpx;
}

.section-head {
  display: flex;
  flex-direction: column;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.section-tip {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #999999;
}

.product-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-item:last-child {
  border-bottom: none;
}

.rank-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.rank-badge {
  width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 50%;
  background-color: #FF6B35;
  color: #ffffff;
  text-align: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.rank-info {
  flex: 1;
  min-width: 0;
}

.rank-title-row,
.rank-meta-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.product-profit {
  font-size: 30rpx;
  font-weight: bold;
  color: #22a06b;
}

.score-bar-bg {
  width: 100%;
  height: 16rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-top: 14rpx;
}

.score-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #22a06b 0%, #7bd88f 100%);
}

.rank-meta-row {
  margin-top: 12rpx;
  color: #777777;
  font-size: 22rpx;
  line-height: 1.4;
}

.cost-warning {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  border-radius: 10rpx;
  background-color: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
}

.cost-warning-row {
  background-color: #fff7e6;
  color: #b26a00;
}

.empty-state {
  padding: 96rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}
