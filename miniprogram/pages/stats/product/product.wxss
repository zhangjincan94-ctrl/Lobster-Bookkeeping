.page {
  padding-bottom: 40rpx;
  min-height: 100vh;
}

.filter-card {
  margin: 16rpx 24rpx;
  padding: 16rpx 24rpx;
}

.filter-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.picker-item {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.picker-label {
  font-size: 22rpx;
  color: #999999;
}

.picker-value {
  font-size: 28rpx;
  color: #333333;
  margin-top: 4rpx;
}

.picker-sep {
  font-size: 26rpx;
  color: #999999;
  padding: 0 16rpx;
}

.summary-card {
  margin: 0 24rpx 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-around;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.summary-value {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: #999999;
}

.product-list {
  padding: 0 24rpx;
}

.product-item {
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.product-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.product-row-sub {
  margin-top: 8rpx;
  margin-bottom: 0;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.product-amount {
  font-size: 30rpx;
  font-weight: bold;
}

.product-bar-bg {
  width: 100%;
  height: 16rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.product-bar-fill {
  height: 100%;
  background-color: #FF6B35;
  border-radius: 8rpx;
}

.product-sub {
  font-size: 24rpx;
}

.product-ratio {
  color: #FF6B35;
  font-weight: bold;
}

.empty-state {
  padding: 96rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}
