.page {
  padding-bottom: 40rpx;
  min-height: 100vh;
}

.summary-card {
  margin: 16rpx 24rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-label {
  font-size: 26rpx;
  color: #999999;
}

.summary-value {
  font-size: 48rpx;
  font-weight: bold;
  margin: 12rpx 0 8rpx;
}

.summary-sub {
  font-size: 24rpx;
}

.debt-list {
  padding: 0 24rpx;
}

.debt-item {
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.debt-head {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.debt-rank {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background-color: #FF6B35;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
  line-height: 56rpx;
  margin-right: 16rpx;
}

.debt-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.debt-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.debt-sub {
  font-size: 22rpx;
}

.debt-amount-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.debt-amount {
  font-size: 32rpx;
  font-weight: bold;
}

.debt-amount-sub {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.debt-foot {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.debt-foot-text {
  font-size: 22rpx;
  flex: 1;
  margin-right: 16rpx;
}

.debt-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.debt-action {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid #FF6B35;
  color: #FF6B35;
  margin-left: 12rpx;
  background-color: #ffffff;
  line-height: 1.4;
}

.debt-action::after {
  border: none;
}

.debt-action-share {
  background-color: #FF6B35;
  color: #ffffff;
  font-weight: normal;
}

.empty-state {
  padding: 96rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}
