<view class="page">
  <view class="card summary-card">
    <text class="summary-label">合计欠款</text>
    <text class="summary-value text-debt">{{totalDebtDisplay}}</text>
    <text class="summary-sub text-muted">共 {{list.length}} 位买家未结清</text>
  </view>

  <view wx:if="{{list.length === 0 && !loading}}" class="empty-state">
    <text class="empty-text">没有欠款记录</text>
  </view>

  <view wx:else class="debt-list">
    <view class="debt-item card" wx:for="{{list}}" wx:key="buyerId">
      <view class="debt-head">
        <view class="debt-rank">{{item.rank}}</view>
        <view class="debt-info" bindtap="goBuyerDetail" data-id="{{item.buyerId}}">
          <text class="debt-name">{{item.buyerName}}</text>
          <text class="debt-sub text-muted">{{item.orderCount}} 笔 · 最近 {{item.lastTimeDisplay}}</text>
        </view>
        <view class="debt-amount-wrap">
          <text class="debt-amount text-debt">{{item.debtAmountDisplay}}</text>
          <text class="debt-amount-sub text-muted">未收款</text>
        </view>
      </view>
      <view class="debt-foot">
        <text class="debt-foot-text text-muted">总额 {{item.totalAmountDisplay}} · 已付 {{item.paidAmountDisplay}}</text>
        <view class="debt-actions">
          <view wx:if="{{item.buyerPhone}}" class="debt-action" bindtap="callPhone" data-phone="{{item.buyerPhone}}">拨打</view>
          <button class="debt-action debt-action-share" open-type="share" data-item="{{item}}">催款</button>
        </view>
      </view>
    </view>
  </view>
</view>
