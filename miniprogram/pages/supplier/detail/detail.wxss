.page {
  padding-bottom: 40rpx;
  min-height: 100vh;
}

.supplier-card {
  margin: 16rpx 24rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
}

.supplier-head {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.supplier-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.supplier-edit {
  font-size: 26rpx;
  color: #FF6B35;
  padding: 8rpx 16rpx;
}

.supplier-row {
  margin-top: 12rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.supplier-phone {
  font-size: 28rpx;
  flex: 1;
}

.supplier-call {
  font-size: 24rpx;
  color: #FF6B35;
  padding: 4rpx 12rpx;
  border: 2rpx solid #FF6B35;
  border-radius: 24rpx;
}

.supplier-remark {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.stats-card {
  margin: 0 24rpx 16rpx;
  padding: 24rpx;
}

.stats-row {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stats-value {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #999999;
}

.stats-foot {
  margin-top: 16rpx;
  text-align: center;
  font-size: 24rpx;
}

.action-bar {
  margin: 0 24rpx 16rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 16rpx 24rpx;
}

.action-btn {
  flex: 1;
  font-size: 28rpx;
  padding: 16rpx 0;
  text-align: center;
  border-radius: 12rpx;
  line-height: 1.5;
  margin: 0 8rpx;
}

.action-btn::after {
  border: none;
}

.action-btn-primary {
  background-color: #FF6B35;
  color: #ffffff;
}

.section-header {
  padding: 24rpx 24rpx 8rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.purchase-list {
  padding: 0 24rpx;
}

.purchase-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.purchase-left {
  display: flex;
  flex-direction: column;
  flex: 1;
  margin-right: 24rpx;
}

.purchase-type {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.purchase-sub {
  font-size: 24rpx;
}

.purchase-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.purchase-amount {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.purchase-bottom-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.purchase-time {
  font-size: 22rpx;
  margin-right: 12rpx;
}

.loading-tip {
  text-align: center;
  padding: 24rpx 0;
  font-size: 24rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  padding: 32rpx 24rpx 16rpx;
  color: #333333;
}

.modal-body {
  padding: 16rpx 24rpx;
}

.modal-field {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
}

.modal-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  text-align: right;
}

.modal-actions {
  display: flex;
  flex-direction: row;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  font-size: 30rpx;
  padding: 24rpx 0;
  text-align: center;
  border: none;
  border-radius: 0;
  line-height: 1.5;
  background-color: #ffffff;
}

.modal-btn::after {
  border: none;
}

.modal-btn-cancel {
  color: #999999;
  border-right: 1rpx solid #f0f0f0;
}

.modal-btn-confirm {
  color: #FF6B35;
  font-weight: bold;
}
