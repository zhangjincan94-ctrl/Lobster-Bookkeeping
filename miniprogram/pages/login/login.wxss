.login-page {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 0 60rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 16rpx;
}

.logo-icon {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.logo-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #FF6B35;
}

.subtitle {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 120rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #07C160;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  text-align: center;
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  background-color: #07C160;
  color: rgba(255, 255, 255, 0.6);
  opacity: 0.8;
}

.terms-text {
  font-size: 22rpx;
  color: #999999;
  margin-top: 40rpx;
}
