.page {
  padding: 24rpx 24rpx 140rpx;
  min-height: 100vh;
}

.form-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  padding: 24rpx 0 8rpx;
}

.form-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  min-height: 88rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  text-align: right;
}

.form-picker {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999999;
  margin-left: 8rpx;
}

.form-item-supplier {
  position: relative;
}

.supplier-input-wrap {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
}

.supplier-dropdown {
  position: absolute;
  left: 0;
  right: 0;
  top: 100%;
  margin-top: 4rpx;
  background-color: #ffffff;
  border: 1rpx solid #eeeeee;
  border-radius: 8rpx;
  max-height: 320rpx;
  z-index: 50;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.supplier-dropdown-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
}

.supplier-dropdown-empty {
  padding: 20rpx 0;
  font-size: 26rpx;
  text-align: center;
}

.radio-group {
  flex: 1;
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  flex-wrap: wrap;
}

.radio-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-left: 16rpx;
  font-size: 26rpx;
}

.total-amount {
  flex: 1;
  text-align: right;
  font-size: 32rpx;
}

.form-textarea {
  flex: 1;
  min-height: 120rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #333333;
  text-align: right;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx 40rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.submit-btn {
  background-color: #FF6B35;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.submit-btn::after {
  border: none;
}
