<view class="page">
  <view class="filter-bar">
    <scroll-view class="status-tabs" scroll-x="true">
      <view class="status-tab {{activeStatus === '' ? 'status-tab-active' : ''}}" bindtap="onStatusTap" data-status="">全部</view>
      <view class="status-tab {{activeStatus === '0' ? 'status-tab-active' : ''}}" bindtap="onStatusTap" data-status="0">未结清</view>
      <view class="status-tab {{activeStatus === '2' ? 'status-tab-active' : ''}}" bindtap="onStatusTap" data-status="2">部分付款</view>
      <view class="status-tab {{activeStatus === '1' ? 'status-tab-active' : ''}}" bindtap="onStatusTap" data-status="1">已结清</view>
    </scroll-view>
  </view>

  <view class="range-filter">
    <view class="range-tab {{activeRange === 'today' ? 'range-tab-active' : ''}}" bindtap="onRangeTap" data-range="today">今天</view>
    <view class="range-tab {{activeRange === 'week' ? 'range-tab-active' : ''}}" bindtap="onRangeTap" data-range="week">近7天</view>
    <view class="range-tab {{activeRange === 'month' ? 'range-tab-active' : ''}}" bindtap="onRangeTap" data-range="month">近30天</view>
    <view class="range-tab {{activeRange === 'all' ? 'range-tab-active' : ''}}" bindtap="onRangeTap" data-range="all">全部</view>
  </view>

  <view class="date-filter">
    <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
      <view class="date-picker">
        <text class="{{startDate ? '' : 'text-muted'}}">{{startDate || '开始日期'}}</text>
      </view>
    </picker>
    <text class="date-separator">至</text>
    <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
      <view class="date-picker">
        <text class="{{endDate ? '' : 'text-muted'}}">{{endDate || '结束日期'}}</text>
      </view>
    </picker>
  </view>

  <view wx:if="{{purchases.length === 0 && !loading}}" class="empty-state">
    <text class="empty-text">暂无进货记录</text>
  </view>

  <view wx:else class="purchase-list">
    <view
      class="purchase-item card"
      wx:for="{{purchases}}"
      wx:key="id"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <view class="purchase-left">
        <text class="purchase-supplier">{{item.supplierName}}</text>
        <text class="purchase-sub text-muted">{{item.lobsterSize}} {{item.netWeight ? item.netWeight + '斤' : ''}} {{item.remainingWeight ? '剩余' + item.remainingWeight + '斤' : ''}}</text>
      </view>
      <view class="purchase-right">
        <text class="purchase-amount text-price">{{item.totalCostDisplay}}</text>
        <view class="purchase-bottom-row">
          <text class="purchase-time text-muted">{{item.timeDisplay}}</text>
          <text class="tag {{item.settlementStatusClass}}">{{item.settlementStatusText}}</text>
        </view>
      </view>
    </view>
    <view wx:if="{{loading}}" class="loading-tip">
      <text class="text-muted">加载中...</text>
    </view>
    <view wx:if="{{!hasMore && purchases.length > 0}}" class="loading-tip">
      <text class="text-muted">没有更多了</text>
    </view>
  </view>

  <view class="fab" bindtap="goAddPurchase">
    <text class="fab-icon">+</text>
  </view>
</view>
