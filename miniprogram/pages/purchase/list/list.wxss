.page {
  padding-bottom: 120rpx;
  min-height: 100vh;
}

.filter-bar {
  background-color: #ffffff;
  padding: 16rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.status-tabs {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
}

.status-tab {
  display: inline-block;
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  color: #666666;
  border-radius: 32rpx;
  margin-right: 16rpx;
  background-color: #f5f5f5;
}

.status-tab-active {
  background-color: #FF6B35;
  color: #ffffff;
}

.range-filter {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 24rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #f5f5f5;
}

.range-tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  margin-right: 12rpx;
  border-radius: 28rpx;
  background-color: #f5f5f5;
  color: #666666;
  font-size: 24rpx;
}

.range-tab:last-child {
  margin-right: 0;
}

.range-tab-active {
  background-color: #FF6B35;
  color: #ffffff;
}

.date-filter {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.date-picker {
  padding: 12rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.date-separator {
  margin: 0 16rpx;
  font-size: 24rpx;
  color: #999999;
}

.purchase-list {
  padding: 16rpx 24rpx;
}

.purchase-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.purchase-left {
  display: flex;
  flex-direction: column;
  flex: 1;
  margin-right: 24rpx;
}

.purchase-supplier {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.purchase-sub {
  font-size: 24rpx;
}

.purchase-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.purchase-amount {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.purchase-bottom-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.purchase-time {
  font-size: 22rpx;
  margin-right: 12rpx;
}

.loading-tip {
  text-align: center;
  padding: 24rpx 0;
  font-size: 24rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 108rpx;
  height: 108rpx;
  border-radius: 54rpx;
  background-color: #FF6B35;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 52rpx;
  color: #ffffff;
  line-height: 1;
}
