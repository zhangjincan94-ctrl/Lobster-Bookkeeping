.page {
  padding: 24rpx 24rpx 140rpx;
  min-height: 100vh;
}

.detail-card {
  padding: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-value-edit {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.edit-link {
  margin-left: 16rpx;
  color: #FF6B35;
  font-size: 26rpx;
}

.modal-tip {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.info-label {
  font-size: 26rpx;
  color: #999999;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  text-align: right;
}

.payment-action {
  display: flex;
  justify-content: flex-end;
  padding-top: 16rpx;
}

.remark-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.7;
}

.payment-record {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.payment-record:last-child {
  border-bottom: none;
}

.payment-record-left {
  display: flex;
  flex-direction: column;
}

.payment-record-amount {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.payment-record-method,
.payment-record-time {
  font-size: 24rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx 40rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.bottom-btn {
  flex: 1;
  width: auto;
  margin: 0;
}

.btn-share {
  background-color: #2F80ED;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.btn-share::after {
  border: none;
}

.btn-danger {
  background-color: #ffffff;
  color: #E74C3C;
  border: 2rpx solid #E74C3C;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.btn-danger::after {
  border: none;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  padding: 32rpx 24rpx 16rpx;
  color: #333333;
}

.modal-body {
  padding: 16rpx 24rpx;
}

.modal-field {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
}

.modal-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  text-align: right;
}

.modal-picker {
  font-size: 28rpx;
  color: #333333;
}

.modal-actions {
  display: flex;
  flex-direction: row;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  font-size: 30rpx;
  padding: 24rpx 0;
  text-align: center;
  border: none;
  border-radius: 0;
  line-height: 1.5;
  background-color: #ffffff;
}

.modal-btn::after {
  border: none;
}

.modal-btn-cancel {
  color: #999999;
  border-right: 1rpx solid #f0f0f0;
}

.modal-btn-confirm {
  color: #FF6B35;
  font-weight: bold;
}
