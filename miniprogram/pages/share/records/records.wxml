<view class="page" wx:if="{{buyer}}">
  <view class="buyer-card card">
    <text class="buyer-name">{{buyer.name}}</text>
    <text class="buyer-phone text-muted">{{buyer.phone || '未填写电话'}}</text>
  </view>

  <view class="stats-card card">
    <view class="stats-row">
      <view class="stats-item">
        <text class="stats-value text-price">{{totalSpent}}</text>
        <text class="stats-label">累计消费</text>
      </view>
      <view class="stats-item">
        <text class="stats-value text-debt">{{totalDebt}}</text>
        <text class="stats-label">当前欠款</text>
      </view>
    </view>
  </view>

  <view class="section-header">
    <text class="section-title">交易明细</text>
  </view>

  <view wx:if="{{transactions.length === 0}}" class="empty-state">
    <text class="empty-text">暂无交易记录</text>
  </view>

  <view wx:else class="transaction-list">
    <view
      class="transaction-item card"
      wx:for="{{transactions}}"
      wx:key="id"
    >
      <view class="transaction-top">
        <view class="transaction-left">
          <text class="transaction-type">{{item.lobsterSize}}</text>
          <text class="transaction-sub text-muted">{{item.weightDisplay}} | {{item.unitPriceDisplay}}</text>
        </view>
        <view class="transaction-right">
          <text class="transaction-amount text-price">{{item.totalAmountDisplay}}</text>
        </view>
      </view>
      <view class="transaction-bottom">
        <text class="transaction-time text-muted">{{item.timeDisplay}}</text>
        <text class="tag {{item.paymentStatusClass}}">{{item.paymentStatusText}}</text>
      </view>
    </view>
  </view>
</view>
