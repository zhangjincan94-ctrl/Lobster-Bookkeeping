.page {
  padding: 24rpx 24rpx 40rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.supplier-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 24rpx;
}

.supplier-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.supplier-phone {
  font-size: 28rpx;
}

.detail-card {
  padding: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999999;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  text-align: right;
}

.remark-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.7;
}

.payment-record {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.payment-record:last-child {
  border-bottom: none;
}

.payment-record-left {
  display: flex;
  flex-direction: column;
}

.payment-record-amount {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.payment-record-method,
.payment-record-time {
  font-size: 24rpx;
}
