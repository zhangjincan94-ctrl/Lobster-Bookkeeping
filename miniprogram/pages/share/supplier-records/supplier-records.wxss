.page {
  padding-bottom: 40rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.buyer-card {
  margin: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 24rpx;
}

.buyer-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.buyer-phone {
  font-size: 28rpx;
}

.stats-card {
  margin: 0 24rpx 16rpx;
}

.stats-row {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stats-value {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #999999;
}

.section-header {
  padding: 24rpx 24rpx 8rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.transaction-list {
  padding: 0 24rpx;
}

.transaction-item {
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.transaction-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.transaction-left {
  display: flex;
  flex-direction: column;
  flex: 1;
  margin-right: 24rpx;
}

.transaction-type {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.transaction-sub {
  font-size: 24rpx;
}

.transaction-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.transaction-amount {
  font-size: 32rpx;
  font-weight: bold;
}

.transaction-bottom {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.transaction-time {
  font-size: 22rpx;
}
