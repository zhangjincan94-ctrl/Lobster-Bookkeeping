<view class="page">
  <view class="header">
    <view class="avatar">🦞</view>
    <view class="header-info">
      <text class="shop-name">{{shopName}}</text>
      <text class="phone text-muted">{{phone || '未设置联系电话'}}</text>
    </view>
  </view>

  <view class="menu-card card">
    <view class="menu-title">店铺设置</view>
    <view class="menu-item" bindtap="onEditShop">
      <text class="menu-label">店铺名称</text>
      <view class="menu-right">
        <text class="menu-value text-muted">{{shopName}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="onEditPhone">
      <text class="menu-label">联系电话</text>
      <view class="menu-right">
        <text class="menu-value text-muted">{{phone || '未设置'}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="menu-card card">
    <view class="menu-title">客户管理</view>
    <view class="menu-item" bindtap="goBuyer">
      <text class="menu-label">买家管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goSupplier">
      <text class="menu-label">供应商管理</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-card card">
    <view class="menu-title">统计报表</view>
    <view class="menu-item" bindtap="goStatsOverview">
      <text class="menu-label">经营总览</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goStatsDebt">
      <text class="menu-label">欠款排行</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goStatsProduct">
      <text class="menu-label">品种分析</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-card card">
    <view class="menu-item" bindtap="onLogout">
      <text class="menu-label text-danger">退出登录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showEditModal}}" bindtap="onCloseEditModal">
  <view class="modal-content" catchtap="noop">
    <view class="modal-title">{{editTitle}}</view>
    <view class="modal-body">
      <input
        class="modal-input"
        placeholder="{{editPlaceholder}}"
        value="{{editValue}}"
        bindinput="onEditInput"
        focus="{{showEditModal}}"
        cursor-spacing="80"
      />
    </view>
    <view class="modal-actions">
      <button class="modal-btn modal-btn-cancel" bindtap="onCloseEditModal">取消</button>
      <button class="modal-btn modal-btn-confirm" bindtap="onEditSubmit" loading="{{submitting}}" disabled="{{submitting}}">保存</button>
    </view>
  </view>
</view>
