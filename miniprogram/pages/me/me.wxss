.page {
  min-height: 100vh;
  background: #F5F6F8;
  padding-bottom: 32rpx;
}

.header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 60rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  color: #fff;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-right: 24rpx;
}

.header-info {
  display: flex;
  flex-direction: column;
}

.shop-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8) !important;
}

.menu-card {
  margin: 24rpx 24rpx 0;
  padding: 0;
  border-radius: 16rpx;
  background: #fff;
  overflow: hidden;
}

.menu-title {
  padding: 24rpx 32rpx 12rpx;
  font-size: 26rpx;
  color: #999;
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-top: 1rpx solid #F2F2F2;
}

.menu-card .menu-item:first-child {
  border-top: none;
}

.menu-label {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  color: #C0C0C0;
  font-size: 36rpx;
}

.menu-right {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.menu-value {
  font-size: 26rpx;
  margin-right: 12rpx;
  max-width: 320rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.text-danger {
  color: #E74C3C !important;
}

.text-muted {
  color: #999;
}

/* Modal */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}

.modal-body {
  margin-bottom: 32rpx;
}

.modal-input {
  border: 1rpx solid #E5E5E5;
  border-radius: 8rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  background: #FAFAFA;
}

.modal-actions {
  display: flex;
  flex-direction: row;
}

.modal-btn {
  flex: 1;
  margin: 0 12rpx;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  padding: 0;
}

.modal-btn-cancel {
  background: #F2F2F2;
  color: #666;
}

.modal-btn-confirm {
  background: #FF6B35;
  color: #fff;
}
